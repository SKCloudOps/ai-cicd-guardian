{
  "name": "ai-cicd-guardian",
  "version": "1.0.0",
  "description": "AI-powered CI/CD pipeline analysis - code review, release notes, test failure analysis, and deployment risk assessment",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.js -o dist --source-map --license licenses.txt",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ __tests__/",
    "format": "prettier --write 'src/**/*.js' '__tests__/**/*.js'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SKCloudOps/ai-cicd-guardian"
  },
  "keywords": [
    "github-action",
    "ai",
    "ci-cd",
    "code-review",
    "release-notes",
    "test-analysis",
    "deployment",
    "devops"
  ],
  "author": "SKCloudOps",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0"
  }
}
